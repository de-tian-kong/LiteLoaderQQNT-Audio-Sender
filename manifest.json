{
    "manifest_version": 4,
    "type": "extension",
    "name": "音频发送",
    "slug": "audio_sender",
    "description": "支持拖拽发送音频文件到聊天窗口。",
    "version": "1.0.0",
    "icon": "./icon.png",
    "authors": [
        {
            "name": "Mousher Lily",
            "link": "https://github.com/lclichen"
        }
    ],
    "platform": [
        "win32",
        "linux",
        "darwin"
    ],
    "injects": {
        "renderer": "./src/renderer.js",
        "main": "./src/main.js",
        "preload": "./src/preload.js"
    },
    "repository": {
        "repo": "lclichen/LiteLoaderQQNT-TTS",
        "branch": "main",
        "release": {
            "tag": "1.0.0"
        }
    }
}
